{
  "name": "soundshine-bot",
  "version": "1.0.0",
  "description": "soundSHINE Bot for Discord",
  "homepage": "https://github.com/n3m01726/soundshine-bot#readme",
  "bugs": {
    "url": "https://github.com/n3m01726/soundshine-bot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n3m01726/soundshine-bot.git"
  },
  "main": "src/index.js",
  "type": "module",
  "license": "ISC",
  "author": "",
  "private": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "discord",
    "bot",
    "soundshine",
    "music",
    "nodejs",
    "javascript"
  ],
  "files": [
    "src/",
    "scripts/",
    "README.md"
  ],
  "overrides": {
    "glob": "^9.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.1",
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@babel/types": "^7.28.2",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.2.0",
    "chalk": "^5.5.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "eslint": "^9.32.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.1",
    "fast-glob": "^3.3.3",
    "ffmpeg-static": "^5.2.0",
    "helmet": "^8.1.0",
    "inquirer": "^12.9.0",
    "node-cron": "^4.2.1",
    "octokit": "^5.0.3",
    "opusscript": "^0.0.7",
    "strip-ansi": "^7.1.0",
    "winston": "^3.17.0",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "dotenv-cli": "^10.0.0",
    "globals": "^16.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "vitest": ">=4.1.0"
  },
  "scripts": {
    "start:dev": "dotenv -e .env.dev -- nodemon  --trace-warnings src/index.js",
    "start:prod": "dotenv -e .env.prod -- node src/index.js",
    "deploy:dev": "dotenv -e .env.dev -- node scripts/bot/deploy-commands.js --dev",
    "clear:dev": "dotenv -e .env.dev -- node scripts/bot/deploy-commands.js --dev --clear",
    "clear:global": "dotenv -e .env.prod -- node scripts/bot/deploy-commands.js --global --clear",
    "deploy:global": "dotenv -e .env.prod -- node scripts/bot/deploy-commands.js --global",
    "db:deploy": "node scripts/dev/init-db.js",
    "git-actions": "node scripts/git/git-actions.js",
    "test": "vitest --config src/config/vitest.config.js",
    "lint": "eslint src/bot src/api src/core --config src/config/eslint.config.js",
    "lint:fix": "eslint src/bot src/api src/core --config src/config/eslint.config.js --fix",
    "context:full": "node ./scripts/tools/projectContext.js --md --full",
    "tree": "node ./scripts/tools/tree.js"
  },
  "imports": {
    "#shared/*": "./src/shared/*",
    "#core/*": "./src/core/*",
    "#bot/*": "./src/bot/*",
    "#api/*": "./src/api/*"
  }
}
